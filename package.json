{
  "name": "op-automation-reporting-service",
  "version": "1.0.0",
  "description": "Service to connect to SDK and periodically fetch JSON data and save to database",
  "main": "server.js",
  "author": "Murugesh",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha",
    "format": "prettier --write .",
    "gcloud-install": "export TOKEN=$(gcloud auth print-access-token) && npm install"
