    "@fastify/swagger-ui": "^5.2.5",
    "@google-cloud/storage": "^7.19.0",
    "op-automation-reporting": "github:murugesh5473/op-automation-reporting#master",
    "axios": "^0.27.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "fastify": "^5.1.0",
    "fastify-metrics": "^12.1.0",
    "mongo": "^0.1.0",
    "mongodb": "^4.17.2",
    "node-cron": "^3.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.8.0"
  },
  "devDependencies": {
    "chai": "^4.3.0",
    "chai-http": "^4.3.0",
    "eslint": "^8.30.0",
    "mocha": "^10.2.0",
    "nodemon": "^2.0.22",
    "prettier": "^3.8.1"
  }
